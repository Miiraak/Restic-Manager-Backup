{
  "general": {
    "restic_exe": "Restic\\restic.exe",
    "log_dir": "logs",
    "log_retention_days": 30,
    "verbose": true,
    "compression": "auto",
    "one_file_system": false,
    "tags": [],
    "exclude_caches": true,
    "exclude_if_present": [".nobackup"]
  },

  "sources": [
    "C:\\Users\\%USERNAME%\\Documents",
    "C:\\Users\\%USERNAME%\\Pictures",
    "C:\\Users\\%USERNAME%\\Desktop"
  ],

  "exclusions": [
    "*.tmp",
    "*.log",
    "~$*",
    "Thumbs.db",
    "desktop.ini",
    "$RECYCLE.BIN",
    "System Volume Information",
    "pagefile.sys",
    "hiberfil.sys",
    "*.iso"
  ],

  "retention": {
    "keep_last":    5,
    "keep_daily":   7,
    "keep_weekly":  4,
    "keep_monthly": 6,
    "keep_yearly":  1
  },

  "backends": {

    "s3": {
      "enabled": false,
      "description": "Swiss Backup – Infomaniak S3",
      "repository": "s3:https://s3.swiss-backup01.infomaniak.com/default",
      "password":   "your-restic-repository-password",
      "env": {
        "AWS_ACCESS_KEY_ID":     "your-s3-access-key",
        "AWS_SECRET_ACCESS_KEY": "your-s3-secret-key"
      }
    },

    "swift": {
      "enabled": false,
      "description": "Swiss Backup – Infomaniak Swift",
      "repository": "swift:default:/restic",
      "password":   "your-restic-repository-password",
      "env": {
        "OS_AUTH_URL":            "https://swiss-backup01.infomaniak.com/identity/v3",
        "OS_IDENTITY_API_VERSION": "3",
        "OS_USER_DOMAIN_NAME":    "default",
        "OS_PROJECT_DOMAIN_NAME": "default",
        "OS_PROJECT_NAME":        "sb_project_SBI-AB123456",
        "OS_TENANT_NAME":         "sb_project_SBI-AB123456",
        "OS_USERNAME":            "SBI-AB123456",
        "OS_PASSWORD":            "your-swift-password",
        "OS_REGION_NAME":         "RegionOne"
      }
    },

    "sftp": {
      "enabled": false,
      "description": "SFTP remote server",
      "repository": "sftp:user@backup-server.example.com:/srv/restic-repos/myrepo",
      "password":   "your-restic-repository-password",
      "env": {}
    },

    "local": {
      "enabled": true,
      "description": "Local disk repository",
      "repository": "repos\\local",
      "password":   "your-restic-repository-password",
      "env": {}
    },

    "usb": {
      "enabled": true,
      "description": "USB key / external drive",
      "drive_label": "BACKUP_USB",
      "repository_path": "ResticRepo",
      "password":   "your-restic-repository-password",
      "env": {}
    }

  }
}
